  },
  {
    "id": "dataset=decision_decision_commonwealth_1905_decision_commonwealth_1905_9ff1e908_62",
    "doc_id": "dataset=decision_decision_commonwealth_1905_decision_commonwealth_1905_9ff1e908",
    "original_source_path": "newapp/dataset=decision/decision/commonwealth/1905/decision_commonwealth_1905_9ff1e908.json",
    "text": "One of the charges on a particular occasion an action for defamation was against the appellant by a discharged servant of the ny. He had in the course of his duty written a letter ich was alleged to be defamatory, and the jury took that view ning that the matter was defamatory. Ido not think there H.C. or A. 1905. = CrowLey v Guissan. (No. 2).",
    "version_id": "high_court_of_australia:/showbyHandle/1/14123",
