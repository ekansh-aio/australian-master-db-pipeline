        "procedural_history": 0.505043089389801,
        "factual_background": 0.3659166097640991,
        "legal_issues": 0.4522969722747803,
        "legal_analysis": 0.3879881799221039,
        "holdings_and_conclusions": 0.5564990639686584,
        "other": 0.33358579874038696
